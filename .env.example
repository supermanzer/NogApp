# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database Configuration (if using PostgreSQL)
DJANGO_DATABASE_ENGINE=postgresql_psycopg2
# DATABASE_URL=postgresql://user:password@localhost:5432/nogapp

# Superuser/Admin Credentials (required for first deployment)
# Change these to your desired admin credentials
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=your-strong-password-here

# Push Notifications Configuration (if enabled)
# Generate VAPID keys: python manage.py generate_vapid_keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_ADMIN_EMAIL=admin@yourdomain.com

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Application-specific settings
PYTHONUNBUFFERED=1
